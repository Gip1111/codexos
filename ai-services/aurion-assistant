#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" = "--version" ]; then
  echo "Aurion Assistant alpha mock 0.1"
  exit 0
fi

cat <<'EOF'
Aurion Assistant - Alpha Task Layer

This alpha uses a safe local task router. It does not download a model or use
cloud AI. Planned local provider: Ollama with phi4-mini.

Try:
  read my email
  install vlc
  check wifi drivers
  aurion-hw-scan

Type a question and press Enter. Type exit to quit.
EOF

while true; do
  printf '\naurion> '
  IFS= read -r question || break
  case "$question" in
    exit|quit) break ;;
    "") continue ;;
  esac

  if command -v aurion-ai-service >/dev/null 2>&1; then
    aurion-ai-service "$question"
  elif command -v aurion-task-assist >/dev/null 2>&1; then
    aurion-task-assist "$question"
  else
    cat <<EOF
Alpha response:
I cannot call a model in v0.1 yet. Open Aurion Experience for guided actions.
Command: aurion-experience
EOF
  fi
done
