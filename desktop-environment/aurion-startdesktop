#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  --check)
    echo "AurionOS Native Preview session"
    command -v aurion-de-shell >/dev/null 2>&1 && echo "aurion-de-shell: available" || echo "aurion-de-shell: missing"
    command -v aurion-native-home >/dev/null 2>&1 && echo "aurion-native-home: available" || echo "aurion-native-home: missing"
    aurion-window-manager --status
    exit 0
    ;;
  --help|-h)
    echo "Usage: aurion-startdesktop [--check]"
    exit 0
    ;;
esac

export DESKTOP_SESSION="AurionOS Native Preview"
export XDG_SESSION_DESKTOP="AurionOS-Native"
export XDG_CURRENT_DESKTOP="AurionOS:Native"
export AURIONOS_SESSION="native-preview"

if [ -n "${DISPLAY:-}" ]; then
  if command -v openbox >/dev/null 2>&1 && ! pgrep -u "$(id -u)" -x openbox >/dev/null 2>&1; then
    openbox >/dev/null 2>&1 &
  fi

  if command -v pcmanfm-qt >/dev/null 2>&1 && ! pgrep -u "$(id -u)" -f 'pcmanfm-qt.*--desktop' >/dev/null 2>&1; then
    pcmanfm-qt --desktop --profile=lxqt >/dev/null 2>&1 &
  fi
fi

aurion-de-shell --mode topbar >/tmp/aurion-topbar.log 2>&1 &
aurion-de-shell --mode dock >/tmp/aurion-dock.log 2>&1 &
aurion-native-home --page experience >/tmp/aurion-native-home.log 2>&1 &

wait
