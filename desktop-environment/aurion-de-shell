def build_window(mode):
    if mode == "topbar":
        return TopBar()
    if mode == "dock":
        return Dock()
    if mode == "launcher":
        return Launcher()
    if mode == "settings":
        return Settings()
    if mode == "files":
        return Files()
    if mode == "notifications":
        return Notifications()
    if mode == "login":
        return LoginPreview()
    return DesktopHub()


def main():
    parser = argparse.ArgumentParser(description="Aurion Desktop Environment alpha shell")
    parser.add_argument("--mode", default="desktop", choices=["desktop", "topbar", "dock", "launcher", "settings", "files", "notifications", "login"])
    parser.add_argument("--path", action="store_true")
    args = parser.parse_args()
    if args.path:
        print(os.path.realpath(__file__))
        return 0
    app = QtWidgets.QApplication(sys.argv)
    app.setApplicationName("Aurion Desktop Environment")
    window = build_window(args.mode)
    window.show()
    return app.exec_()


if __name__ == "__main__":
    sys.exit(main())
