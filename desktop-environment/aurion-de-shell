#!/usr/bin/env python3
import argparse
import os
import shlex
import shutil
import subprocess
import sys
from datetime import datetime

from PyQt5 import QtCore, QtGui, QtWidgets


ICON_DIR = "/usr/share/icons/hicolor/scalable/apps"
NOTIFICATION_LOG = os.path.expanduser("~/.local/share/aurionos/notifications.log")


def icon(name):
    path = os.path.join(ICON_DIR, name)
    if os.path.exists(path):
        return QtGui.QIcon(path)
    themed = QtGui.QIcon.fromTheme(os.path.splitext(name)[0])
    if not themed.isNull():
        return themed
    return QtGui.QIcon.fromTheme("applications-system")


def run_command(command):
    try:
        subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except OSError as exc:
        QtWidgets.QMessageBox.warning(None, "AurionOS", f"Cannot launch {' '.join(command)}:\n{exc}")


def run_action(action):
    run_command(["aurion-action", f"aurion-action://{action}"])


def run_terminal(title, command):
    quoted = " ".join(shlex.quote(part) for part in command)
    shell_command = f"{quoted}; printf '\\n'; read -r -p 'Premi Invio per chiudere...'"
    if shutil.which("qterminal"):
        run_command(["qterminal", "-T", title, "-e", "bash", "-lc", shell_command])
    elif shutil.which("x-terminal-emulator"):
        run_command(["x-terminal-emulator", "-e", "bash", "-lc", shell_command])
    else:
        run_command(command)


class AButton(QtWidgets.QPushButton):
    def __init__(self, text, icon_name=None, accent=False):
        super().__init__(text)
        if icon_name:
            self.setIcon(icon(icon_name))
            self.setIconSize(QtCore.QSize(28, 28))
        self.setCursor(QtCore.Qt.PointingHandCursor)
        self.setProperty("accent", accent)
        self.setMinimumHeight(34)


class Tile(QtWidgets.QPushButton):
    def __init__(self, title, body, icon_name, callback):
        super().__init__(f"{title}\n{body}")
        self.setIcon(icon(icon_name))
        self.setIconSize(QtCore.QSize(34, 34))
        self.setCursor(QtCore.Qt.PointingHandCursor)
        self.setMinimumHeight(96)
        self.setProperty("tile", True)
        self.clicked.connect(callback)


class ShellWindow(QtWidgets.QWidget):
    def __init__(self, title="AurionOS"):
        super().__init__()
        self.setWindowTitle(title)
        self.setWindowIcon(icon("aurionos.svg"))
        self.setStyleSheet(STYLE)

    def center(self, width, height):
        screen = QtWidgets.QApplication.primaryScreen().availableGeometry()
        self.setGeometry(
            screen.x() + (screen.width() - width) // 2,
            screen.y() + (screen.height() - height) // 2,
            width,
            height,
        )


class TopBar(ShellWindow):
    def __init__(self):
        super().__init__("Aurion TopBar")
        self.setWindowFlags(QtCore.Qt.Tool | QtCore.Qt.FramelessWindowHint | QtCore.Qt.WindowStaysOnTopHint)
        screen = QtWidgets.QApplication.primaryScreen().availableGeometry()
        self.setGeometry(screen.x(), screen.y(), screen.width(), 38)
        layout = QtWidgets.QHBoxLayout(self)
        layout.setContentsMargins(10, 4, 10, 4)
        layout.setSpacing(8)
        layout.addWidget(AButton("Aurion", "aurionos.svg"))
        layout.addStretch(1)
        for index in range(1, 5):
            button = AButton(str(index), accent=index == 1)
            button.setFixedWidth(36)
            layout.addWidget(button)
        layout.addStretch(1)
        for label, action in (("Wi-Fi", "hardware"), ("Audio", "settings"), ("Notifiche", "notifications")):
            button = AButton(label)
            button.clicked.connect(lambda _=False, a=action: route_mode(a))
            layout.addWidget(button)
        self.clock = QtWidgets.QLabel()
        self.clock.setProperty("muted", True)
        layout.addWidget(self.clock)
        power = AButton("Power")
        power.clicked.connect(lambda: run_action("system-details"))
        layout.addWidget(power)
        self.timer = QtCore.QTimer(self)
        self.timer.timeout.connect(self.update_clock)
        self.timer.start(1000)
        self.update_clock()

    def update_clock(self):
        self.clock.setText(datetime.now().strftime("%H:%M"))


