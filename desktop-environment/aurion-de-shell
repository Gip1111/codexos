class Files(ShellWindow):
    def __init__(self):
        super().__init__("Aurion Files")
        self.center(900, 620)
        self.current = os.path.expanduser("~")
        layout = QtWidgets.QVBoxLayout(self)
        layout.setContentsMargins(18, 18, 18, 18)
        header = QtWidgets.QHBoxLayout()
        self.path_label = QtWidgets.QLabel()
        self.path_label.setProperty("pageTitle", True)
        header.addWidget(self.path_label, 1)
        for label, callback in (("Home", self.go_home), ("Su", self.go_up), ("PCManFM", lambda: run_action("files"))):
            button = AButton(label)
            button.clicked.connect(callback)
            header.addWidget(button)
        layout.addLayout(header)
        self.listing = QtWidgets.QListWidget()
        self.listing.itemDoubleClicked.connect(self.open_item)
        layout.addWidget(self.listing, 1)
        self.load_path(self.current)

    def load_path(self, path):
        self.current = path
        self.path_label.setText(os.path.basename(path) or path)
        self.listing.clear()
        try:
            entries = sorted(os.scandir(path), key=lambda e: (not e.is_dir(), e.name.lower()))
        except OSError as exc:
            QtWidgets.QMessageBox.warning(self, "Aurion Files", str(exc))
            return
        for entry in entries:
            item = QtWidgets.QListWidgetItem(entry.name)
            item.setData(QtCore.Qt.UserRole, entry.path)
            item.setIcon(QtGui.QIcon.fromTheme("folder" if entry.is_dir() else "text-x-generic"))
            self.listing.addItem(item)

    def open_item(self, item):
        path = item.data(QtCore.Qt.UserRole)
        if os.path.isdir(path):
            self.load_path(path)
        else:
            run_command(["xdg-open", path])

    def go_home(self):
        self.load_path(os.path.expanduser("~"))

    def go_up(self):
        self.load_path(os.path.dirname(self.current))


class Notifications(ShellWindow):
    def __init__(self):
        super().__init__("Aurion Notifications")
        self.center(520, 620)
        layout = QtWidgets.QVBoxLayout(self)
        layout.setContentsMargins(18, 18, 18, 18)
        title = QtWidgets.QLabel("Centro notifiche")
        title.setProperty("pageTitle", True)
        layout.addWidget(title)
        self.listing = QtWidgets.QListWidget()
        layout.addWidget(self.listing, 1)
        row = QtWidgets.QHBoxLayout()
        refresh = AButton("Aggiorna")
        refresh.clicked.connect(self.load)
        clear = AButton("Svuota")
        clear.clicked.connect(self.clear)
        sample = AButton("Prova notifica", accent=True)
        sample.clicked.connect(lambda: run_command(["aurion-notify", "AurionOS", "Centro notifiche attivo"]))
        row.addWidget(refresh)
        row.addWidget(clear)
        row.addWidget(sample)
        layout.addLayout(row)
        self.load()

    def load(self):
        self.listing.clear()
        if os.path.exists(NOTIFICATION_LOG):
            with open(NOTIFICATION_LOG, "r", encoding="utf-8", errors="replace") as handle:
                for line in handle.readlines()[-80:]:
                    self.listing.addItem(line.strip())
        if self.listing.count() == 0:
            self.listing.addItem("Nessuna notifica recente.")

    def clear(self):
        os.makedirs(os.path.dirname(NOTIFICATION_LOG), exist_ok=True)
        open(NOTIFICATION_LOG, "w", encoding="utf-8").close()
        self.load()


