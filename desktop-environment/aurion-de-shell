def route_mode(mode):
    wrappers = {
        "settings": ["aurion-settings"],
        "files": ["aurion-files"],
        "notifications": ["aurion-notifications"],
        "launcher": ["aurion-launcher"],
        "topbar": ["aurion-de-shell", "--mode", "topbar"],
        "dock": ["aurion-de-shell", "--mode", "dock"],
        "login": ["aurion-login-preview"],
        "hardware": ["aurion-hardware-center"],
    }
    run_command(wrappers.get(mode, ["aurion-de-shell", "--mode", mode]))


