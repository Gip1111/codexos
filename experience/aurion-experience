#!/usr/bin/env bash
set -euo pipefail

page="/usr/share/aurionos/experience/index.html"

if [ "${1:-}" = "--path" ]; then
  if command -v aurion-webapp-open >/dev/null 2>&1; then
    exec aurion-webapp-open --path "$page"
  fi
  echo "$page"
  exit 0
fi

if [ ! -f "$page" ]; then
  echo "Aurion Experience page is missing: $page" >&2
  exit 1
fi

if [ "${AURION_EXPERIENCE_BACKEND:-qml}" != "html" ] && [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ] && command -v aurion-qml-surface >/dev/null 2>&1; then
  exec aurion-qml-surface --page experience
fi

exec aurion-webapp-open AurionExperience "$page"
