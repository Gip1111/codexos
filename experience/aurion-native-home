            )
            layout.addWidget(InfoCard("Stato alpha", "Se Ollama non e' pronto, Aurion usa il router locale sicuro. Nessun dato lascia il dispositivo.", "Nuova conversazione", lambda: self.run_action("ai")))
            layout.addStretch(1)

        return self.shell(fill)

    def build_control_page(self):
        def fill(layout):
            self.page_title(layout, "Control Center", "Superfici native per sistema, software, hardware, rollback e AI.")
            self.tile_grid(
                layout,
                [
                    Tile("Stato sistema", "aurion-status", "aurion-terminal.svg", lambda: self.run_action("status-report")),
                    Tile("Store", "Catalogo app", "aurion-store.svg", lambda: self.set_page("store")),
                    Tile("Hardware", "Compatibilita", "aurion-hardware.svg", lambda: self.set_page("hardware")),
                    Tile("Rollback", "Snapshot plan", "aurion-snapshot.svg", lambda: self.run_action("backup")),
                    Tile("AI", "Provider locale", "aurion-assistant.svg", lambda: self.set_page("ai")),
                    Tile("Installer", "Calamares", "aurion-installer.svg", lambda: self.run_action("installer")),
                ],
            )
            layout.addStretch(1)

        return self.shell(fill)

    def set_page(self, page):
        aliases = {
            "desktop": "home",
            "experience": "home",
            "overview": "home",
            "launcher": "home",
            "apps": "store",
            "assistant": "ai",
            "ai-status": "ai",
            "settings": "control",
        }
        page = aliases.get(page or "home", page)
        if page not in self.pages:
            page = "home"
        self.active_page = page
        self.stack.setCurrentWidget(self.pages[page])

    def run_action(self, name):
        try:
            subprocess.Popen(["aurion-action", f"aurion-action://{name}"])
        except OSError:
            QtWidgets.QMessageBox.warning(self, "Aurion action", f"Action unavailable: {name}")

    def handle_task(self, text):
        q = (text or "").lower()
        if any(word in q for word in ("mail", "email", "posta")):
            self.run_action("email")
        elif any(word in q for word in ("install", "app", "programma")):
            self.set_page("store")
        elif any(word in q for word in ("wifi", "driver", "hardware")):
            self.set_page("hardware")
        elif any(word in q for word in ("diagn", "errore", "sistema")):
            self.set_page("diagnostics")
        elif any(word in q for word in ("ai", "ollama")):
            self.set_page("ai")
        else:
            self.set_page("control")

    def mousePressEvent(self, event):
        if event.button() == QtCore.Qt.LeftButton and event.pos().y() <= self.header.height():
            self.drag_pos = event.globalPos() - self.frameGeometry().topLeft()
            event.accept()

    def mouseMoveEvent(self, event):
        if self.drag_pos and event.buttons() & QtCore.Qt.LeftButton:
            self.move(event.globalPos() - self.drag_pos)
            event.accept()

    def mouseReleaseEvent(self, event):
        self.drag_pos = None
        super().mouseReleaseEvent(event)

