def parse_page(argv):
    page = "home"
    args = list(argv[1:])
    if "--path" in args:
        print(os.path.realpath(__file__))
        sys.exit(0)
    while args:
        arg = args.pop(0)
        if arg == "--page" and args:
            page = args.pop(0)
        elif arg in ("--help", "-h"):
            print("Usage: aurion-native-home [--page experience|store|hardware|diagnostics|ai|control] [--path]")
            sys.exit(0)
    return page


def main():
    page = parse_page(sys.argv)
    app = QtWidgets.QApplication(sys.argv)
    app.setApplicationName("Aurion Experience")
    app.setOrganizationName("AurionOS")
    window = AurionHome(page)
    window.show()
    return app.exec_()


if __name__ == "__main__":
    sys.exit(main())
