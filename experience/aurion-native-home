                layout,
                [
                    Tile("Firefox", "Browser web", "aurion-browser.svg", lambda: self.run_action("browser")),
                    Tile("LibreOffice", "Documenti e ufficio", "aurion-store.svg", lambda: self.run_action("install-libreoffice")),
                    Tile("VLC", "Lettore multimediale", "aurion-store.svg", lambda: self.run_action("install-vlc")),
                    Tile("OBS Studio", "Registrazione e streaming", "aurion-store.svg", lambda: self.run_action("install-obs")),
                    Tile("GIMP", "Editing immagini", "aurion-files.svg", lambda: self.run_action("install-gimp")),
                    Tile("VS Code", "Sviluppo", "aurion-terminal.svg", lambda: self.run_action("install-code")),
