                    Tile("Spiega hardware", "Diagnosi guidata", "aurion-hardware.svg", lambda: self.set_page("hardware")),
                    Tile("Aiuto app", "Scegli formato installazione", "aurion-store.svg", lambda: self.set_page("store")),
