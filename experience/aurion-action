#!/usr/bin/env bash
set -euo pipefail

uri="${1:-}"
action="$uri"
action="${action#aurion-action://}"
action="${action%%\?*}"
action="${action%%/*}"
action="${action,,}"

launch() {
  if command -v "$1" >/dev/null 2>&1; then
    "$@" >/dev/null 2>&1 &
    exit 0
  fi
}

open_url() {
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$1" >/dev/null 2>&1 &
    exit 0
  fi
}

terminal_run() {
  local title="$1"
  shift
  local command
  printf -v command '%q ' "$@"

  if command -v qterminal >/dev/null 2>&1; then
    qterminal -T "$title" -e bash -lc "$command; printf '\n'; read -r -p 'Premi Invio per chiudere...'" >/dev/null 2>&1 &
    exit 0
  fi

  if command -v x-terminal-emulator >/dev/null 2>&1; then
    x-terminal-emulator -e bash -lc "$command; printf '\n'; read -r -p 'Premi Invio per chiudere...'" >/dev/null 2>&1 &
    exit 0
  fi

  bash -lc "$command"
}

case "$action" in
  experience|home|"")
    launch aurion-experience
    ;;
  browser|web)
    open_url "https://www.google.com"
    ;;
  email|mail)
    open_url "https://mail.google.com"
    ;;
  files|file-manager)
    launch pcmanfm-qt "$HOME"
    ;;
  terminal|shell)
    launch qterminal
    launch x-terminal-emulator
    ;;
  store|apps|more-apps)
    launch aurion-store
    terminal_run "Aurion Store" aurion-store --cli
    ;;
  install-app)
    terminal_run "Aurion Store" aurion-store --request app
    ;;
  install-obs)
    terminal_run "Aurion Store" aurion-store --request "OBS Studio"
    ;;
  install-gimp)
    terminal_run "Aurion Store" aurion-store --request GIMP
    ;;
  install-vlc)
    terminal_run "Aurion Store" aurion-store --request "VLC Media Player"
    ;;
  install-firefox)
    terminal_run "Aurion Store" aurion-store --request Firefox
    ;;
  install-libreoffice)
    terminal_run "Aurion Store" aurion-store --request LibreOffice
    ;;
  install-code)
    terminal_run "Aurion Store" aurion-store --request "Visual Studio Code"
    ;;
  install-thunderbird)
    terminal_run "Aurion Store" aurion-store --request Thunderbird
    ;;
  install-bitwarden)
    terminal_run "Aurion Store" aurion-store --request Bitwarden
    ;;
  installer|install-os)
    launch calamares
    ;;
  ai|assistant|conversation)
    launch aurion-ai-sidebar
    ;;
  ai-setup)
    terminal_run "Aurion AI Setup" aurion-ai-setup --status
    ;;
  ai-instructions)
    terminal_run "Aurion AI Instructions" aurion-ai-setup --instructions
    ;;
  ai-install-ollama)
    terminal_run "Aurion AI Runtime" aurion-ai-setup --install-ollama
    ;;
  ai-pull-model)
    terminal_run "Aurion AI Model" aurion-ai-setup --pull-model
    ;;
  wifi|hardware|network)
    launch aurion-hardware-center
    terminal_run "Aurion Hardware" aurion-hardware-center --cli
    ;;
  hardware-scan)
    terminal_run "Aurion Hardware Scan" aurion-hw-scan
    ;;
  diagnostics)
    launch aurion-diagnostics
    terminal_run "Aurion Diagnostics" aurion-diagnostics --cli
    ;;
  diagnostics-report)
    terminal_run "Aurion Diagnostics Report" aurion-diagnostics --cli
    ;;
  desktop-check)
    terminal_run "Aurion Desktop Check" aurion-desktop-check
    ;;
  system-details|status|status-report)
    terminal_run "Aurion Status" aurion-status
    ;;
  backup)
    terminal_run "Aurion Rollback" aurion-snapshot-plan
    ;;
  settings|security|services|system|software)
    launch aurion-shell --page control
    ;;
  *)
    terminal_run "Aurion Task" aurion-task-assist "$action"
    ;;
esac
