#!/usr/bin/env bash
set -euo pipefail

value_or_unknown() {
  if [ -n "${1:-}" ]; then
    printf '%s\n' "$1"
  else
    printf 'unknown\n'
  fi
}

join_lines() {
  awk 'BEGIN { sep = "" } { printf "%s%s", sep, $0; sep = "; " } END { print "" }'
}

line() {
  printf '%-20s %s\n' "$1" "$2"
}

os_name="unknown"
if [ -r /etc/os-release ]; then
  # shellcheck disable=SC1091
  . /etc/os-release
  os_name="${PRETTY_NAME:-unknown}"
fi

line "OS:" "$os_name"
line "Kernel:" "$(uname -r)"

if [ -d /sys/firmware/efi ]; then
  line "Boot mode:" "UEFI"
else
  line "Boot mode:" "legacy BIOS or EFI unavailable"
fi

if command -v mokutil >/dev/null 2>&1; then
  secure_boot="$(mokutil --sb-state 2>/dev/null | join_lines)"
  line "Secure Boot:" "$(value_or_unknown "$secure_boot")"
else
  line "Secure Boot:" "mokutil unavailable"
fi

line "Desktop session:" "${DESKTOP_SESSION:-unknown}"
line "Current desktop:" "${XDG_CURRENT_DESKTOP:-unknown}"
line "Session desktop:" "${XDG_SESSION_DESKTOP:-unknown}"

if command -v calamares >/dev/null 2>&1; then
  line "Installer:" "Calamares present"
else
  line "Installer:" "Calamares not found"
fi

if command -v nmcli >/dev/null 2>&1; then
  line "Network:" "$(nmcli -t -f STATE general 2>/dev/null || echo unknown)"
  wifi="$(nmcli -t -f DEVICE,TYPE,STATE device 2>/dev/null | awk -F: '$2 == "wifi" { print $1 " " $3 }' | paste -sd ', ' -)"
  line "Wi-Fi:" "$(value_or_unknown "$wifi")"
else
  line "Network:" "nmcli unavailable"
fi

if [ -r /usr/share/aurionos/release/channel.conf ]; then
  line "Channel:" "$(awk -F= '$1 == "AURIONOS_CHANNEL" { print $2 }' /usr/share/aurionos/release/channel.conf)"
fi

printf '\nAurionOS tools:\n'
for tool in \
  aurion-control \
  aurion-shell \
  aurion-qml-surface \
  aurion-launcher \
  aurion-ai-sidebar \
  aurion-topbar \
  aurion-dock \
  aurion-experience \
  aurion-hub \
  aurion-status \
  aurion-startlxqt \
  aurion-startlabwc \
  aurion-session-guard \
  aurion-session-watchdog \
  aurion-apply-live-branding \
  aurion-action \
  aurion-webapp-open \
  aurion-channel \
  aurion-desktop-check \
  aurion-assistant \
  aurion-ai-status \
  aurion-ai-status-gui \
  aurion-ai-service \
  aurion-ai-setup \
  aurion-do \
  aurion-task-assist \
  aurion-install \
  aurion-appimage-integrate \
  aurion-hardware-center \
  aurion-hardware-gui \
  aurion-hw-scan \
  aurion-store \
  aurion-store-gui \
  aurion-snapshot-plan \
  aurion-diagnostics \
  aurion-diagnostics-gui \
  aurion-rollback-status; do
  if command -v "$tool" >/dev/null 2>&1; then
    printf '  [ok] %s\n' "$tool"
  else
    printf '  [missing] %s\n' "$tool"
  fi
done
