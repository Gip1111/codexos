#!/usr/bin/env bash
set -euo pipefail

page="/usr/share/aurionos/diagnostics/index.html"

if [ "${1:-}" = "--path" ]; then
  if command -v aurion-webapp-open >/dev/null 2>&1; then
    exec aurion-webapp-open --path "$page"
  fi
  echo "$page"
  exit 0
fi

if [ ! -f "$page" ]; then
  echo "Aurion Diagnostics page is missing: $page" >&2
  exit 1
fi

exec aurion-webapp-open AurionDiagnostics "$page"
