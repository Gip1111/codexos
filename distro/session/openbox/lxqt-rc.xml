<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <resistance>
    <strength>10</strength>
    <screen_edge_strength>20</screen_edge_strength>
  </resistance>
  <focus>
    <focusNew>yes</focusNew>
    <followMouse>no</followMouse>
    <raiseOnFocus>no</raiseOnFocus>
  </focus>
  <theme>
    <name>AurionOS</name>
    <titleLayout>NLIMC</titleLayout>
    <keepBorder>yes</keepBorder>
    <animateIconify>yes</animateIconify>
    <font place="ActiveWindow"><name>Noto Sans</name><size>10</size><weight>Bold</weight></font>
    <font place="InactiveWindow"><name>Noto Sans</name><size>10</size><weight>Normal</weight></font>
    <font place="MenuHeader"><name>Noto Sans</name><size>10</size><weight>Bold</weight></font>
    <font place="MenuItem"><name>Noto Sans</name><size>10</size><weight>Normal</weight></font>
  </theme>
  <desktops>
    <number>2</number>
    <firstdesk>1</firstdesk>
    <names><name>Aurion</name><name>Work</name></names>
  </desktops>
  <keyboard>
    <chainQuitKey>C-g</chainQuitKey>
    <keybind key="W-Space"><action name="Execute"><command>aurion-launcher</command></action></keybind>
    <keybind key="W-e"><action name="Execute"><command>aurion-experience</command></action></keybind>
    <keybind key="W-a"><action name="Execute"><command>aurion-ai-sidebar</command></action></keybind>
    <keybind key="W-s"><action name="Execute"><command>qterminal -e aurion-store</command></action></keybind>
    <keybind key="W-h"><action name="Execute"><command>qterminal -e aurion-hardware-center</command></action></keybind>
  </keyboard>
</openbox_config>
