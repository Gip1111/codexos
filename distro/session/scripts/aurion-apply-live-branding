#!/usr/bin/env bash
set -euo pipefail

wallpaper="/usr/share/backgrounds/aurionos/aurionos-alpha.png"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/pcmanfm-qt/lxqt"
config_file="$config_dir/settings.conf"
user_config="${XDG_CONFIG_HOME:-$HOME/.config}"
skel_config="/etc/skel/.config"
welcome="/usr/share/aurionos/experience/index.html"
welcome_marker="${XDG_STATE_HOME:-$HOME/.local/state}/aurionos/welcome-shown"
visual_marker="${XDG_STATE_HOME:-$HOME/.local/state}/aurionos/visual-profile-applied"

cleanup_legacy_desktop_launchers() {
  local desktop_dir="$HOME/Desktop"
  local launcher

  [ -d "$desktop_dir" ] || return 0

  for launcher in "$desktop_dir"/*.desktop; do
    [ -f "$launcher" ] || continue
    if grep -Eiq '(^Name=.*Lubuntu|Try or Install Lubuntu|Install Lubuntu|lubuntu)' "$launcher"; then
      rm -f "$launcher"
    fi
  done
}

export DESKTOP_SESSION="AurionOS"
export XDG_SESSION_DESKTOP="AurionOS"
case ":${XDG_CURRENT_DESKTOP:-}:" in
  *:AurionOS:*) ;;
  ::) export XDG_CURRENT_DESKTOP="LXQt:AurionOS" ;;
  *) export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP}:AurionOS" ;;
esac

[ -f "$wallpaper" ] || exit 0
mkdir -p "$config_dir"

python3 - "$config_file" "$wallpaper" <<'PY'
import configparser
import os
import sys

config_file, wallpaper = sys.argv[1], sys.argv[2]
parser = configparser.ConfigParser()
parser.optionxform = str

if os.path.exists(config_file):
    parser.read(config_file)

# pcmanfm-qt legge la configurazione wallpaper dalla sezione "*" (default
# per tutti gli schermi). Manteniamo anche la vecchia sezione [Desktop]
# per compatibilita' con eventuali letture legacy.
for section in ("*", "Desktop"):
    if section not in parser:
        parser[section] = {}
    s = parser[section]
    s["Wallpaper"] = wallpaper
    s["wallpaper"] = wallpaper
    s["WallpaperMode"] = "stretch"
    s["wallpaper_mode"] = "stretch"

with open(config_file, "w", encoding="utf-8") as fh:
    parser.write(fh)
PY

if command -v pcmanfm-qt >/dev/null 2>&1; then
  pcmanfm-qt --set-wallpaper="$wallpaper" >/dev/null 2>&1 || true
fi

if [ ! -e "$visual_marker" ]; then
  mkdir -p "$(dirname "$visual_marker")" "$user_config/lxqt" "$user_config/openbox" "$HOME/Desktop"

  for name in lxqt.conf panel.conf session.conf globalkeyshortcuts.conf; do
    if [ -f "$skel_config/lxqt/$name" ]; then
      cp -f "$skel_config/lxqt/$name" "$user_config/lxqt/$name"
    fi
  done

  if [ -f "$skel_config/openbox/lxqt-rc.xml" ]; then
    cp -f "$skel_config/openbox/lxqt-rc.xml" "$user_config/openbox/lxqt-rc.xml"
  fi

  if [ -d /etc/skel/Desktop ]; then
    for launcher in /etc/skel/Desktop/*.desktop; do
      [ -f "$launcher" ] || continue
      cp -f "$launcher" "$HOME/Desktop/$(basename "$launcher")"
      chmod 0755 "$HOME/Desktop/$(basename "$launcher")"
    done
  fi

  cleanup_legacy_desktop_launchers

  mkdir -p "$(dirname "$visual_marker")"
  touch "$visual_marker"

  if command -v openbox >/dev/null 2>&1; then
    openbox --reconfigure >/dev/null 2>&1 || true
  fi

  if command -v lxqt-panel >/dev/null 2>&1 \
    && command -v pgrep >/dev/null 2>&1 \
    && command -v pkill >/dev/null 2>&1 \
    && pgrep -x lxqt-panel >/dev/null 2>&1; then
    (
      sleep 1
      pkill -x lxqt-panel >/dev/null 2>&1 || true
      lxqt-panel >/dev/null 2>&1 &
    ) &
  fi
fi

cleanup_legacy_desktop_launchers

if command -v aurion-session-watchdog >/dev/null 2>&1; then
  aurion-session-watchdog --once >/dev/null 2>&1 || true
fi

if [ -f "$welcome" ] && [ ! -e "$welcome_marker" ]; then
  mkdir -p "$(dirname "$welcome_marker")"
  touch "$welcome_marker"
  (
    sleep 4
    if command -v xdg-open >/dev/null 2>&1; then
      xdg-open "$welcome" >/dev/null 2>&1 || true
    fi
  ) &
fi
