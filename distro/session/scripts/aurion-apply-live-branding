#!/usr/bin/env bash
set -euo pipefail

wallpaper="/usr/share/backgrounds/aurionos/aurionos-alpha.png"
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/pcmanfm-qt/lxqt"
config_file="$config_dir/settings.conf"
welcome="/usr/share/aurionos/welcome/index.html"
welcome_marker="${XDG_STATE_HOME:-$HOME/.local/state}/aurionos/welcome-shown"

export DESKTOP_SESSION="AurionOS"
export XDG_SESSION_DESKTOP="AurionOS"
case ":${XDG_CURRENT_DESKTOP:-}:" in
  *:AurionOS:*) ;;
  ::) export XDG_CURRENT_DESKTOP="LXQt:AurionOS" ;;
  *) export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP}:AurionOS" ;;
esac

[ -f "$wallpaper" ] || exit 0
mkdir -p "$config_dir"

python3 - "$config_file" "$wallpaper" <<'PY'
import configparser
import os
import sys

config_file, wallpaper = sys.argv[1], sys.argv[2]
parser = configparser.ConfigParser()
parser.optionxform = str

if os.path.exists(config_file):
    parser.read(config_file)

if "Desktop" not in parser:
    parser["Desktop"] = {}

desktop = parser["Desktop"]
desktop["Wallpaper"] = wallpaper
desktop["wallpaper"] = wallpaper
desktop["WallpaperMode"] = "stretch"
desktop["wallpaper_mode"] = "stretch"

with open(config_file, "w", encoding="utf-8") as fh:
    parser.write(fh)
PY

if command -v pcmanfm-qt >/dev/null 2>&1; then
  pcmanfm-qt --set-wallpaper="$wallpaper" >/dev/null 2>&1 || true
fi

if [ -f "$welcome" ] && [ ! -e "$welcome_marker" ]; then
  mkdir -p "$(dirname "$welcome_marker")"
  touch "$welcome_marker"
  (
    sleep 4
    if command -v xdg-open >/dev/null 2>&1; then
      xdg-open "$welcome" >/dev/null 2>&1 || true
    fi
  ) &
fi
