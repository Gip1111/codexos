LXQt::RunnerDialog {
  background: #111923;
  color: #f8fafc;
}

QLineEdit {
  min-height: 42px;
  border: 1px solid #2d3a4a;
  border-radius: 8px;
  background: #0d131c;
  color: #f8fafc;
  padding: 8px 12px;
}

QListView {
  background: #151f2c;
  color: #f8fafc;
  border: 1px solid #2d3a4a;
  border-radius: 8px;
  padding: 6px;
}

QListView::item {
  min-height: 34px;
  border-radius: 6px;
  padding: 5px;
}

QListView::item:selected {
  background: rgba(245, 193, 92, 50);
}
