/*
  AurionOS Alpha LXQt panel theme.
  Kept dependency-free: pure QSS over the Lubuntu/LXQt base.
*/

LXQtPanel,
QFrame#BackgroundWidget {
  background: rgba(8, 13, 16, 244);
  color: #f8fafc;
  border: 0;
}

QToolButton,
QPushButton {
  background: transparent;
  color: #f8fafc;
  border: 1px solid transparent;
  border-radius: 7px;
  padding: 4px 8px;
  margin: 2px;
}

QToolButton:hover,
QPushButton:hover {
  background: rgba(79, 209, 197, 32);
  border-color: rgba(79, 209, 197, 120);
}

QToolButton:pressed,
QPushButton:pressed,
QToolButton:checked {
  background: rgba(241, 188, 85, 36);
  border-color: rgba(241, 188, 85, 150);
  color: #f1bc55;
}

QMenu {
  background: #0e1518;
  color: #f8fafc;
  border: 1px solid #26373c;
  padding: 8px;
}

QMenu::item {
  min-height: 28px;
  border-radius: 6px;
  padding: 6px 26px 6px 18px;
}

QMenu::item:selected {
  background: rgba(79, 209, 197, 44);
  color: #ffffff;
}

QToolTip {
  background: #0e1518;
  color: #f8fafc;
  border: 1px solid #23c7c9;
  border-radius: 6px;
  padding: 6px;
}
