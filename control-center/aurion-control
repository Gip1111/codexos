#!/usr/bin/env bash
set -euo pipefail

run_or_missing() {
  local tool="$1"
  shift || true
  if command -v "$tool" >/dev/null 2>&1; then
    "$tool" "$@"
  else
    echo "$tool is not installed in this image."
  fi
}

while true; do
  clear 2>/dev/null || true
  cat <<'MENU'
AurionOS Control Center - Alpha Foundation

1. Open Aurion Hub report
2. System status
3. Hardware compatibility
4. AI provider status
5. App Store alpha catalog
6. App install foundation
7. Diagnostics
8. Snapshot planner
9. Rollback status
0. Exit
MENU
  printf '\nSelect: '
  IFS= read -r choice || exit 0
  printf '\n'
  case "$choice" in
    1) run_or_missing aurion-hub ;;
    2) run_or_missing aurion-status ;;
    3) run_or_missing aurion-hardware-center ;;
    4) run_or_missing aurion-ai-status ;;
    5) run_or_missing aurion-store ;;
    6) run_or_missing aurion-install --explain ;;
    7) run_or_missing aurion-diagnostics ;;
    8) run_or_missing aurion-snapshot-plan ;;
    9) run_or_missing aurion-rollback-status ;;
    0|q|quit|exit) exit 0 ;;
    *) echo "Unknown option: $choice" ;;
  esac
  printf '\nPress Enter to continue...'
  IFS= read -r _ || true
done
