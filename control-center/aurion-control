#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  cat <<'EOF'
AurionOS Control Center

Usage:
  aurion-control
  aurion-control --cli

The default desktop path opens the Qt/QML alpha bridge when available and falls
back to the stable graphical HTML surfaces. Use --cli for the terminal menu.
EOF
  exit 0
fi

if [ "${1:-}" != "--cli" ] && [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ] && command -v aurion-settings >/dev/null 2>&1; then
  exec aurion-settings
fi

if [ "${1:-}" != "--cli" ] && [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ] && command -v aurion-qml-surface >/dev/null 2>&1; then
  exec aurion-qml-surface --page control
fi

if [ "${1:-}" = "--cli" ]; then
  shift
fi

run_or_missing() {
  local tool="$1"
  shift || true
  if command -v "$tool" >/dev/null 2>&1; then
    "$tool" "$@"
  else
    echo "$tool is not installed in this image."
  fi
}

while true; do
  clear 2>/dev/null || true
  cat <<'MENU'
AurionOS Control Center - Alpha Foundation

1. Open Aurion Experience
2. Open Aurion Hub report
3. System status
4. Hardware compatibility
5. AI provider status
6. App Store alpha catalog
7. App install foundation
8. Diagnostics
9. Snapshot planner
10. Rollback status
0. Exit
MENU
  printf '\nSelect: '
  IFS= read -r choice || exit 0
  printf '\n'
  case "$choice" in
    1) run_or_missing aurion-experience ;;
    2) run_or_missing aurion-hub ;;
    3) run_or_missing aurion-status ;;
    4) run_or_missing aurion-hardware-center ;;
    5) run_or_missing aurion-ai-status ;;
    6) run_or_missing aurion-store ;;
    7) run_or_missing aurion-install --explain ;;
    8) run_or_missing aurion-diagnostics ;;
    9) run_or_missing aurion-snapshot-plan ;;
    10) run_or_missing aurion-rollback-status ;;
    0|q|quit|exit) exit 0 ;;
    *) echo "Unknown option: $choice" ;;
  esac
  printf '\nPress Enter to continue...'
  IFS= read -r _ || true
done
