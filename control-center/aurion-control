#!/usr/bin/env bash
set -euo pipefail

run_or_missing() {
  local tool="$1"
  shift || true
  if command -v "$tool" >/dev/null 2>&1; then
    "$tool" "$@"
  else
    echo "$tool is not installed in this image."
  fi
}

while true; do
  clear 2>/dev/null || true
  cat <<'MENU'
AurionOS Control Center - Alpha Foundation

1. System status
2. Hardware compatibility
3. AI provider status
4. App Store alpha catalog
5. Diagnostics
6. Rollback status
0. Exit
MENU
  printf '\nSelect: '
  IFS= read -r choice || exit 0
  printf '\n'
  case "$choice" in
    1) run_or_missing aurion-status ;;
    2) run_or_missing aurion-hardware-center ;;
    3) run_or_missing aurion-ai-status ;;
    4) run_or_missing aurion-store ;;
    5) run_or_missing aurion-diagnostics ;;
    6) run_or_missing aurion-rollback-status ;;
    0|q|quit|exit) exit 0 ;;
    *) echo "Unknown option: $choice" ;;
  esac
  printf '\nPress Enter to continue...'
  IFS= read -r _ || true
done
