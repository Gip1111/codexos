#!/usr/bin/env bash
set -euo pipefail

db="/usr/share/aurionos/hardware/alpha-hardware.json"

echo "AurionOS Hardware Center - alpha read-only classification"
echo

if [ ! -r "$db" ]; then
  echo "Hardware database missing: $db"
  echo "Falling back to raw hardware scan."
  exec aurion-hw-scan
fi

if ! command -v lspci >/dev/null 2>&1; then
  echo "lspci is unavailable; raw scan follows."
  exec aurion-hw-scan
fi

pci_output="$(lspci)"
matched=0

awk '
  /"match"/ { match_text=$0; gsub(/[\",]/, "", match_text); sub(/^ *match: */, "", match_text) }
  /"status"/ { status=$0; gsub(/[\",]/, "", status); sub(/^ *status: */, "", status) }
  /"notes"/ {
    notes=$0; gsub(/[\",]/, "", notes); sub(/^ *notes: */, "", notes)
    if (match_text != "") print match_text "\t" status "\t" notes
    match_text=""; status=""; notes=""
  }
' "$db" | while IFS=$'\t' read -r match_text status notes; do
  [ -n "$match_text" ] || continue
  if printf '%s\n' "$pci_output" | grep -Fq "$match_text"; then
    matched=$((matched + 1))
    printf '[known] %s\n' "$match_text"
    printf '        status: %s\n' "${status:-unknown}"
    printf '        notes: %s\n\n' "${notes:-no notes}"
  fi
  printf '%s\n' "$matched" > "${TMPDIR:-/tmp}/aurion-hw-matched.$$"
done

matched="$(cat "${TMPDIR:-/tmp}/aurion-hw-matched.$$" 2>/dev/null || echo 0)"
rm -f "${TMPDIR:-/tmp}/aurion-hw-matched.$$"

if [ "$matched" -eq 0 ]; then
  echo "No database matches yet. Raw hardware scan follows."
  echo
  aurion-hw-scan
else
  echo "Matched devices: $matched"
  echo "Alpha policy: no driver changes were made."
fi
