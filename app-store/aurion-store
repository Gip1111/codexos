#!/usr/bin/env bash
set -euo pipefail

catalog="/usr/share/aurionos/store/alpha-catalog.json"

if [ "${1:-}" = "--path" ]; then
  if [ "${AURION_STORE_BACKEND:-native}" != "html" ] && command -v aurion-native-home >/dev/null 2>&1; then
    exec aurion-native-home --page store --path
  fi
  if [ "${AURION_STORE_BACKEND:-qml}" != "html" ] && command -v aurion-qml-surface >/dev/null 2>&1; then
    exec aurion-qml-surface --page store --path
  fi
  if command -v aurion-store-gui >/dev/null 2>&1; then
    exec aurion-store-gui --path
  fi
  echo "/usr/share/aurionos/store/index.html"
  exit 0
fi

if [ "${1:-}" = "--request" ]; then
  app_name="${2:-selected app}"
  cat <<EOF
Aurion Store install request

Selected app: $app_name

Alpha policy:
- no packages are installed silently
- final flow will show source, permissions, package format, and user confirmation
- Flatpak is the preferred target path
- Snap remains optional during MVP

No changes were made.
EOF
  exit 0
fi

if [ "${1:-}" != "--cli" ] && [ "${AURION_STORE_BACKEND:-native}" != "html" ] && [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ] && command -v aurion-native-home >/dev/null 2>&1; then
  exec aurion-native-home --page store
fi

if [ "${1:-}" != "--cli" ] && [ "${AURION_STORE_BACKEND:-native}" != "html" ] && [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ] && command -v aurion-qml-surface >/dev/null 2>&1; then
  exec aurion-qml-surface --page store
fi

if [ "${1:-}" != "--cli" ] && [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ] && command -v aurion-store-gui >/dev/null 2>&1; then
  exec aurion-store-gui "$@"
fi

if [ "${1:-}" = "--cli" ]; then
  shift
fi

echo "Aurion Store - alpha foundation"
echo

if [ ! -r "$catalog" ]; then
  echo "Catalog missing: $catalog"
  exit 1
fi

echo "Install policy: list-only in this alpha ISO"
echo "Future default: Flatpak-first, Snap optional, .deb and AppImage graphical flows"
echo

echo "Featured catalog:"
awk '
  /"name"/ { gsub(/[",]/, ""); sub(/^ *name: */, ""); name=$0 }
  /"source"/ { gsub(/[",]/, ""); sub(/^ *source: */, ""); source=$0 }
  /"category"/ { gsub(/[",]/, ""); sub(/^ *category: */, ""); category=$0; if (name != "") printf "- %s [%s] via %s\n", name, category, source }
' "$catalog"

echo
echo "No packages were installed. This command is a UX and architecture placeholder."
